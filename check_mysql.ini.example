# check_mysql configuration.
# Copy this file to check_mysql.ini next to the plugin (or into
# /usr/local/etc/nagios or /etc/nagios) and adjust the values.

# --- Direct connection ------------------------------------------------------
[mysql]
host = db.example.com
port = 3306
user = nagios
password = secret
# Optional default schema:
#database = mydb
# Connection timeout in seconds:
timeout = 10

# --- Account security audit (optional) ---------------------------------------
# Tuning for the `security` command. Entries are user@host, exactly like the
# User and Host columns of mysql.user (comma separated, % needs no escaping).
#
#[security]
# Accounts exempted from EVERY check:
#allow = backup@10.0.0.5, debian-sys-maint@localhost, app@%
# Accounts expected to be powerful (exempted from the remote-privileges check
# only — still checked for passwords, wildcard host, etc.):
#admins = dba@10.0.0.0/24, ops@%

# --- SSH tunnel (optional) --------------------------------------------------
# When this section is present, the plugin first opens an SSH tunnel to the
# bastion below, then connects to [mysql] host:port THROUGH the tunnel
# (the MySQL host is resolved from the bastion's point of view).
#
#[ssh]
#host = bastion.example.com
#port = 22
#user = nagios
# Authenticate with a private key (recommended) or a password:
#private_key = ~/.ssh/id_ed25519
#password = only-if-no-key
